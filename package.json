{
  "name": "artis-sdk",
  "version": "1.0.0",
  "description": "Official JavaScript/TypeScript SDK for the Artis platform",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "type": "module",
  "scripts": {
    "test": "vitest",
    "test:run": "vitest run",
    "build": "tsup --clean",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "artis",
    "sdk",
    "storefront",
    "ecommerce"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kaizen-Ai-Agent/artis-sdk.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/kaizen-Ai-Agent/artis-sdk/issues"
  },
  "homepage": "https://github.com/kaizen-Ai-Agent/artis-sdk#readme",
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^2.0.0"
  }
}